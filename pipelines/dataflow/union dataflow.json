{
	"name": "union dataflow",
	"properties": {
		"description": "joining datasets with union all",
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_blob_union_P13",
						"type": "DatasetReference"
					},
					"name": "vskpdata"
				},
				{
					"dataset": {
						"referenceName": "DS_blob_blr_unio_P13",
						"type": "DatasetReference"
					},
					"name": "blrdata"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_DL_union_P13",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          city as string,",
				"          sales as string,",
				"          profit as string,",
				"          month as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> vskpdata",
				"source(output(",
				"          city as string,",
				"          sales as string,",
				"          profit as string,",
				"          month as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> blrdata",
				"vskpdata, blrdata union(byName: true)~> union1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Emp_id as string,",
				"          Emp_name as string,",
				"          Emp_Dept_id as string,",
				"          Emp_Salary as string,",
				"          Location as string,",
				"          Dept_id as string,",
				"          Dept_Name as string",
				"     ),",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}