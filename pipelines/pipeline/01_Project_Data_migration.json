{
	"name": "01_Project_Data_migration",
	"properties": {
		"description": "Data migration project from onprem sql to Azure sql",
		"activities": [
			{
				"name": "On-perm_to_Azure_Sql",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "studentid",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "studentid",
									"type": "Int32",
									"physicalType": "int"
								}
							},
							{
								"source": {
									"name": "stdname",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "stdname",
									"type": "String",
									"physicalType": "varchar"
								}
							},
							{
								"source": {
									"name": "gender",
									"type": "String",
									"physicalType": "char"
								},
								"sink": {
									"name": "gender",
									"type": "String",
									"physicalType": "char"
								}
							},
							{
								"source": {
									"name": "DOB",
									"type": "DateTime",
									"physicalType": "datetime"
								},
								"sink": {
									"name": "DOB",
									"type": "DateTime",
									"physicalType": "datetime"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "DS_on_prem_SQL",
						"type": "DatasetReference",
						"parameters": {
							"Sql_Table_name": {
								"value": "@pipeline().parameters.PP_Sql_table_name",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_Azure_sql_migration",
						"type": "DatasetReference"
					}
				]
			}
		],
		"parameters": {
			"PP_Sql_table_name": {
				"type": "string"
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-03-05T12:08:03Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}