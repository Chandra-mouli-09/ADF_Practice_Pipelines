{
	"name": "P7_delete _file_activity",
	"properties": {
		"description": "to delete the old file in the source as new file get updated in daily basis",
		"activities": [
			{
				"name": "Delete file in source",
				"type": "Delete",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "Ds_delete_activity",
						"type": "DatasetReference"
					},
					"logStorageSettings": {
						"linkedServiceName": {
							"referenceName": "Ls_blob_indian_railways",
							"type": "LinkedServiceReference"
						},
						"path": "new-data"
					},
					"enableLogging": true,
					"storeSettings": {
						"type": "AzureBlobStorageReadSettings",
						"recursive": true,
						"wildcardFileName": "*.txt",
						"enablePartitionDiscovery": false
					}
				}
			}
		],
		"annotations": [],
		"lastPublishTime": "2026-03-01T02:28:22Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
