				"schema": [
					{
						"name": "zone_id",
						"type": "int",
						"precision": 10
					},
					{
						"name": "zone_name",
						"type": "varchar"
					}
				],
				"typeProperties": {
					"schema": "dbo",
					"table": "zone_details"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/LS_Azure_Sql_Database')]"
