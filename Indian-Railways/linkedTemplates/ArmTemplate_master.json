{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Indian-Railways"
		},
		"LS_Azure_Sql_Database_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_Azure_Sql_Database'"
		},
		"LS_Blob_new_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_Blob_new'"
		},
		"Ls_Blob_indian_railways_dynamic_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Ls_Blob_indian_railways_dynamic'",
			"defaultValue": "DefaultEndpointsProtocol=https;AccountName=@{linkedService().Blob_Name};EndpointSuffix=core.windows.net;"
		},
		"Ls_blob_indian_railways_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Ls_blob_indian_railways'"
		},
		"datalake_indian_railways_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake_indian_railways'"
		},
		"LS_Sql_server_on_prem_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_Sql_server_on_prem'"
		},
		"LS_Azure_Sql_Database_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver0911.database.windows.net"
		},
		"LS_Azure_Sql_Database_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "indian-railways"
		},
		"LS_Azure_Sql_Database_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "chandra"
		},
		"Ls_Datalake_indian_railways_dynamic_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "@{linkedService().Datalake_URL}"
		},
		"Ls_india_railways_KeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://Indian-railways-keyvault.vault.azure.net/"
		},
		"datalake_indian_railways_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://datalakeindianrailways.dfs.core.windows.net/"
		},
		"Event_trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/90a98c4c-9b75-4066-b635-bfaed585300a/resourceGroups/Indian_railways_resource_group/providers/Microsoft.Storage/storageAccounts/blobindiarrailways"
		},
		"tumbling trigger_properties_pipeline_parameters_PL_Startdate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowstarttime"
		},
		"tumbling trigger_properties_pipeline_parameters_PL_Enddate": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndtime"
		},
		"LS_Sql_server_on_prem_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": ".\\DATA_ENGINEER_09"
		},
		"LS_Sql_server_on_prem_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "school"
		},
		"LS_Sql_server_on_prem_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "newuser"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Indian-Railways_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_Azure_Sql_Database_password": {
						"value": "[parameters('LS_Azure_Sql_Database_password')]"
					},
					"LS_Blob_new_connectionString": {
						"value": "[parameters('LS_Blob_new_connectionString')]"
					},
					"Ls_blob_indian_railways_connectionString": {
						"value": "[parameters('Ls_blob_indian_railways_connectionString')]"
					},
					"datalake_indian_railways_accountKey": {
						"value": "[parameters('datalake_indian_railways_accountKey')]"
					},
					"LS_Azure_Sql_Database_properties_typeProperties_server": {
						"value": "[parameters('LS_Azure_Sql_Database_properties_typeProperties_server')]"
					},
					"LS_Azure_Sql_Database_properties_typeProperties_database": {
						"value": "[parameters('LS_Azure_Sql_Database_properties_typeProperties_database')]"
					},
					"LS_Azure_Sql_Database_properties_typeProperties_userName": {
						"value": "[parameters('LS_Azure_Sql_Database_properties_typeProperties_userName')]"
					},
					"Ls_india_railways_KeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('Ls_india_railways_KeyVault_properties_typeProperties_baseUrl')]"
					},
					"datalake_indian_railways_properties_typeProperties_url": {
						"value": "[parameters('datalake_indian_railways_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "Indian-Railways_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Ls_Blob_indian_railways_dynamic_connectionString": {
						"value": "[parameters('Ls_Blob_indian_railways_dynamic_connectionString')]"
					},
					"LS_Sql_server_on_prem_password": {
						"value": "[parameters('LS_Sql_server_on_prem_password')]"
					},
					"Ls_Datalake_indian_railways_dynamic_properties_typeProperties_url": {
						"value": "[parameters('Ls_Datalake_indian_railways_dynamic_properties_typeProperties_url')]"
					},
					"LS_Sql_server_on_prem_properties_typeProperties_server": {
						"value": "[parameters('LS_Sql_server_on_prem_properties_typeProperties_server')]"
					},
					"LS_Sql_server_on_prem_properties_typeProperties_database": {
						"value": "[parameters('LS_Sql_server_on_prem_properties_typeProperties_database')]"
					},
					"LS_Sql_server_on_prem_properties_typeProperties_userName": {
						"value": "[parameters('LS_Sql_server_on_prem_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'Indian-Railways_ArmTemplate_0')]"
			]
		},
		{
			"name": "Indian-Railways_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'Indian-Railways_ArmTemplate_1')]"
			]
		},
		{
			"name": "Indian-Railways_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Event_trigger_properties_typeProperties_scope": {
						"value": "[parameters('Event_trigger_properties_typeProperties_scope')]"
					},
					"tumbling trigger_properties_pipeline_parameters_PL_Startdate": {
						"value": "[parameters('tumbling trigger_properties_pipeline_parameters_PL_Startdate')]"
					},
					"tumbling trigger_properties_pipeline_parameters_PL_Enddate": {
						"value": "[parameters('tumbling trigger_properties_pipeline_parameters_PL_Enddate')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'Indian-Railways_ArmTemplate_2')]"
			]
		}
	]
}